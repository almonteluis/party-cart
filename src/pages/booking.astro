---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BookingForm from '../components/BookingForm';
---

<Layout title="Book Your Event | Create It Sis" description="Book your premium mobile party cart rental. Fill out our form and we'll get back to you within 24 hours.">
  <Navigation />

  <!-- Hero -->
  <section class="pt-32 pb-16 px-6 md:px-12 lg:px-20 bg-brand-dark">
    <div class="max-w-6xl mx-auto text-center">
      <span class="section-label">Booking</span>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl mt-4 mb-6">Book Your Event</h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        Fill out the form below and we'll get back to you within 24 hours to finalize the details.
      </p>
    </div>
  </section>

  <!-- Booking Form + Sidebar -->
  <section class="section-padding bg-brand-dark">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Form -->
      <div class="lg:col-span-2">
        <BookingForm client:load />
      </div>

      <!-- Sidebar -->
      <div class="space-y-8">
        <!-- Contact Info -->
        <div class="bg-brand-charcoal rounded-lg p-8">
          <h3 class="font-serif text-xl mb-4">Contact Us</h3>
          <p class="text-white/50 text-sm mb-6">Prefer to talk? Reach out directly.</p>
          <div class="space-y-4">
            <a href="mailto:hello@createitsis.com" class="flex items-center gap-3 text-white/60 hover:text-brand-gold transition-colors">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
              <span>hello@createitsis.com</span>
            </a>
            <a href="tel:+18455550199" class="flex items-center gap-3 text-white/60 hover:text-brand-gold transition-colors">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              <span>(845) 555-0199</span>
            </a>
          </div>
        </div>

        <!-- Quick Info -->
        <div class="bg-brand-charcoal rounded-lg p-8">
          <h3 class="font-serif text-xl mb-4">Good to Know</h3>
          <ul class="space-y-3 text-white/50 text-sm">
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-brand-gold rounded-full mt-1.5 shrink-0"></span>
              We respond within 24 hours
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-brand-gold rounded-full mt-1.5 shrink-0"></span>
              A 50% deposit secures your date
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-brand-gold rounded-full mt-1.5 shrink-0"></span>
              Free delivery within 30 miles
            </li>
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 bg-brand-gold rounded-full mt-1.5 shrink-0"></span>
              Setup and breakdown included
            </li>
          </ul>
        </div>

        <!-- CTA -->
        <div class="bg-brand-gold/10 border border-brand-gold/20 rounded-lg p-8 text-center">
          <h3 class="font-serif text-xl mb-3">Have Questions?</h3>
          <p class="text-white/50 text-sm mb-4">Check out our FAQ or reach out directly.</p>
          <a href="/#faq" class="btn-outline text-sm px-6 py-2.5">View FAQ</a>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
