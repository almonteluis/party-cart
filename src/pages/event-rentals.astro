---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Add-On Services | Create It Sis" description="Enhance your event with our add-on services: dessert cart, event planning, centerpieces, and more.">
  <Navigation />

  <!-- Hero -->
  <section class="pt-32 pb-16 px-6 md:px-12 lg:px-20 bg-brand-dark">
    <div class="max-w-6xl mx-auto text-center">
      <span class="section-label">Add-On Services</span>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl mt-4 mb-6">Make It Extra Special</h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        Elevate your event with our premium add-on services. From creative consulting to full event planning.
      </p>
    </div>
  </section>

  <!-- Add-Ons Grid -->
  <section class="section-padding bg-brand-dark">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

      <!-- Clipart Graphics -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Clipart Graphics</h3>
            <span class="text-brand-gold font-semibold text-xl">$60</span>
          </div>
          <p class="text-white/60 mb-6">Custom clipart and graphics applied to balloons and event decor. Additional materials cost extra.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Custom balloon graphics</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Event-themed designs</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Professional application</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Service</a>
        </div>
      </div>

      <!-- Creative Consulting -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Creative Consulting</h3>
            <span class="text-brand-gold font-semibold text-xl">$500</span>
          </div>
          <p class="text-white/60 mb-6">A creative consultation with our design &amp; research team to create the event of your dreams.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>One-on-one design session</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Mood board &amp; concept</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Vendor recommendations</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Service</a>
        </div>
      </div>

      <!-- Dessert Cart -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="aspect-[4/3] bg-brand-dark overflow-hidden">
          <img src="/images/dessert-cart.png" alt="Luxury Dessert Cart" class="w-full h-full object-contain p-4" />
        </div>
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Dessert Cart</h3>
            <span class="text-brand-gold font-semibold text-xl">$120</span>
          </div>
          <p class="text-white/60 mb-6">A luxury dessert cart to display your cakes, treats &amp; more! Fill not included.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Elegant white finish</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Scalloped canopy</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Mobile with wheels</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Service</a>
        </div>
      </div>

      <!-- Event Planning -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Event Planning</h3>
            <span class="text-brand-gold font-semibold text-xl">$500</span>
          </div>
          <p class="text-white/60 mb-6">Full event planning &amp; coordination. We handle every detail from start to finish.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Complete event coordination</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Vendor management</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Day-of coordination</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Service</a>
        </div>
      </div>

      <!-- Centerpieces -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="aspect-[4/3] bg-brand-dark overflow-hidden">
          <img src="/images/cylinder-pedestals.png" alt="Centerpiece Options" class="w-full h-full object-contain p-4" />
        </div>
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Centerpieces</h3>
            <span class="text-brand-gold font-semibold text-xl">$10-$50+</span>
          </div>
          <p class="text-white/60 mb-6">Shop through our inventory or add post-event cleanup. Custom designs tailored to your event.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Wide variety available</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Balloon centerpieces</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Custom designs</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Service</a>
        </div>
      </div>

      <!-- Arch Frame Specs -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="aspect-[4/3] bg-brand-dark overflow-hidden">
          <img src="/images/arch-frame-specs.jpg" alt="Arch Frame Specifications" class="w-full h-full object-contain p-4" />
        </div>
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Arch Frames</h3>
            <span class="text-brand-gold font-semibold text-xl">$15</span>
          </div>
          <p class="text-white/60 mb-6">Durable arch frames available in two sizes: 4ft x 7.2ft and 2.6ft x 6ft.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Large: 4ft x 7.2ft (1.2m x 2.2m)</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Small: 2.6ft x 6ft (0.8m x 1.8m)</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Sturdy construction</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Service</a>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 md:px-12 lg:px-20 bg-brand-gold text-brand-dark text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl mb-4">Ready to Plan Your Event?</h2>
      <p class="text-brand-dark/70 mb-8">Combine backdrop services and add-ons for the ultimate celebration setup.</p>
      <a href="/booking" class="inline-block bg-brand-dark text-white font-semibold px-8 py-3.5 tracking-wider text-sm uppercase hover:bg-brand-dark/90 transition-all duration-300">Book Now</a>
    </div>
  </section>

  <Footer />
</Layout>
