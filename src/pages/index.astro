---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import FAQAccordion from '../components/FAQAccordion';

const carts = [
  {
    name: 'Candy Cart',
    price: '$275',
    description:
      'A stunning display of sweets and treats that delights guests of all ages. Perfect for weddings, birthdays, and family celebrations.',
  },
  {
    name: 'Champagne Cart',
    price: '$300',
    description:
      'Elevate the toast with our elegant champagne cart. Complete with glassware and all the accessories for a sophisticated celebration.',
  },
  {
    name: 'Snack Cart',
    price: '$275',
    description:
      'A curated selection of savory and sweet snacks presented beautifully. Great for casual events, corporate gatherings, and parties.',
  },
  {
    name: 'Shot Cart',
    price: '$350',
    description:
      'Bring the energy with our premium shot cart. Includes themed shot glasses, a variety of pour options, and stylish presentation.',
  },
];

const packages = [
  {
    name: 'Cart Only',
    price: '$275+',
    description: 'Basic rental, DIY setup.',
    features: [
      'Cart of your choice',
      'Delivery and pickup',
      'Standard setup',
      'DIY stocking and management',
      'Up to 4-hour rental',
    ],
    highlighted: false,
  },
  {
    name: 'Cart + Branding',
    price: '$375+',
    description: 'Custom branding and setup included.',
    features: [
      'Cart of your choice',
      'Custom branded signage and decor',
      'Professional setup and styling',
      'Delivery and pickup',
      'Up to 6-hour rental',
    ],
    highlighted: true,
  },
  {
    name: 'Cart + Branding + Decor',
    price: '$475+',
    description: 'Full service with premium decorations.',
    features: [
      'Cart of your choice',
      'Full custom branding and signage',
      'Premium event decorations',
      'Professional setup and breakdown',
      'Up to 8-hour rental',
    ],
    highlighted: false,
  },
];

const steps = [
  {
    number: '1',
    title: 'Choose Your Rental',
    description: 'Browse our collection of premium carts and select the perfect one for your event.',
  },
  {
    number: '2',
    title: 'Complete the Booking Form',
    description: 'Fill in your event details, date, and any special requests through our simple form.',
  },
  {
    number: '3',
    title: 'Finalize Details',
    description: 'We will confirm availability, discuss customizations, and finalize your booking.',
  },
  {
    number: '4',
    title: 'We Deliver & Set Up',
    description: 'On the big day, we arrive early to deliver, set up, and make sure everything is perfect.',
  },
];
---

<Layout title="Create It Sis | Premier Mobile Party Cart Rentals">
  <Navigation />

  <main>
    <!-- ===================== HERO SECTION ===================== -->
    <section
      id="home"
      class="relative min-h-screen flex items-center justify-center bg-brand-dark"
    >
      <!-- Gradient overlay -->
      <div
        class="absolute inset-0 bg-gradient-to-b from-brand-dark/40 via-brand-dark/20 to-brand-dark pointer-events-none"
        aria-hidden="true"
      ></div>
      <!-- Subtle radial glow -->
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: radial-gradient(ellipse at 50% 40%, rgba(201,168,76,0.08) 0%, transparent 70%)"
      ></div>

      <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
        <h1
          class="font-serif text-5xl md:text-6xl lg:text-7xl text-white leading-tight mb-6"
        >
          Elevate Your Celebration
        </h1>
        <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
          Premium mobile party cart rentals that bring the party to you
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/booking" class="btn-primary">
            Book Now
          </a>
          <a href="/#carts" class="btn-outline">
            View Our Carts
          </a>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="text-white/40"
        >
          <path d="M12 5v14M5 12l7 7 7-7" />
        </svg>
      </div>
    </section>

    <!-- ===================== FEATURED CARTS SECTION ===================== -->
    <section id="carts" class="section-padding">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <span class="section-label">Our Collection</span>
          <h2 class="font-serif text-4xl md:text-5xl text-white mt-3">
            Choose Your Cart
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
          {carts.map((cart) => (
            <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-2 transition-transform duration-300">
              <!-- Placeholder image area -->
              <div class="aspect-[4/3] bg-brand-dark flex items-center justify-center relative overflow-hidden">
                <div class="text-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="40"
                    height="40"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1"
                    class="text-white/20 mx-auto mb-2"
                  >
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <polyline points="21 15 16 10 5 21" />
                  </svg>
                  <span class="text-white/20 text-xs uppercase tracking-wider">
                    {cart.name}
                  </span>
                </div>
                <!-- Hover overlay -->
                <div class="absolute inset-0 bg-brand-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>

              <!-- Card content -->
              <div class="p-6">
                <div class="flex items-baseline justify-between mb-3">
                  <h3 class="font-serif text-xl text-white">{cart.name}</h3>
                  <span class="text-brand-gold font-semibold text-lg">{cart.price}</span>
                </div>
                <p class="text-white/50 text-sm leading-relaxed mb-4">
                  {cart.description}
                </p>
                <a
                  href="/carts"
                  class="inline-flex items-center text-brand-gold text-sm font-medium hover:text-brand-gold/80 transition-colors duration-300 group/link"
                >
                  Learn More
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    class="ml-1 transform group-hover/link:translate-x-1 transition-transform duration-300"
                  >
                    <path d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== PACKAGES SECTION ===================== -->
    <section id="packages" class="section-padding bg-brand-charcoal">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <span class="section-label">Packages</span>
          <h2 class="font-serif text-4xl md:text-5xl text-white mt-3">
            Find Your Perfect Package
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto">
          {packages.map((pkg) => (
            <div
              class={`relative rounded-lg p-8 flex flex-col ${
                pkg.highlighted
                  ? 'bg-brand-dark border-2 border-brand-gold'
                  : 'bg-brand-dark border border-white/10'
              }`}
            >
              {pkg.highlighted && (
                <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                  <span class="bg-brand-gold text-brand-dark text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-full">
                    Most Popular
                  </span>
                </div>
              )}

              <div class="text-center mb-6">
                <h3 class="font-serif text-2xl text-white mb-2">{pkg.name}</h3>
                <p class="text-white/50 text-sm mb-4">{pkg.description}</p>
                <div class="text-brand-gold font-serif text-4xl">{pkg.price}</div>
              </div>

              <ul class="space-y-3 mb-8 flex-grow">
                {pkg.features.map((feature) => (
                  <li class="flex items-start gap-3 text-white/70 text-sm">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      class="text-brand-gold flex-shrink-0 mt-0.5"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>

              <a
                href="/booking"
                class={`block text-center font-semibold px-8 py-3.5 tracking-wider text-sm uppercase transition-all duration-300 ${
                  pkg.highlighted
                    ? 'bg-brand-gold text-brand-dark hover:bg-brand-gold/90'
                    : 'border border-white/60 text-white hover:bg-white hover:text-brand-dark'
                }`}
              >
                Get Started
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== HOW IT WORKS SECTION ===================== -->
    <section id="how-it-works" class="section-padding">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <span class="section-label">How It Works</span>
          <h2 class="font-serif text-4xl md:text-5xl text-white mt-3">
            Simple as 1-2-3-4
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8 max-w-5xl mx-auto relative">
          {steps.map((step, i) => (
            <div class="text-center relative">
              <!-- Number circle -->
              <div class="w-16 h-16 rounded-full border-2 border-brand-gold flex items-center justify-center mx-auto mb-5 relative z-10 bg-brand-dark">
                <span class="font-serif text-2xl text-brand-gold">{step.number}</span>
              </div>
              <h3 class="font-serif text-xl text-white mb-3">{step.title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>

        <!-- Desktop connector line -->
        <div class="hidden lg:block max-w-[52rem] mx-auto -mt-[calc(11rem+40px)] mb-20 px-20" aria-hidden="true">
          <div class="h-px bg-white/10 mx-8"></div>
        </div>
      </div>
    </section>

    <!-- ===================== ABOUT PREVIEW SECTION ===================== -->
    <section id="about" class="section-padding bg-brand-charcoal">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <span class="section-label">About Us</span>
          <h2 class="font-serif text-4xl md:text-5xl text-white mt-3">
            We Bring the Party to You
          </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Text content -->
          <div>
            <p class="text-white/70 text-base md:text-lg leading-relaxed mb-6">
              Create It Sis is a premier mobile party cart rental service dedicated to
              making every celebration unforgettable. From intimate gatherings to grand
              events, our beautifully styled carts add a touch of elegance and fun that
              your guests will remember.
            </p>
            <p class="text-white/70 text-base md:text-lg leading-relaxed mb-8">
              Founded with a passion for creating memorable experiences, we handle
              everything from delivery and setup to styling and customization. Whether
              you are planning a wedding, corporate event, birthday, or any special
              occasion, we have the perfect cart for you.
            </p>
            <a href="/about" class="btn-primary">
              Learn More
            </a>
          </div>

          <!-- Placeholder image area -->
          <div class="aspect-[4/3] bg-brand-dark rounded-lg flex items-center justify-center">
            <div class="text-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="56"
                height="56"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                class="text-white/15 mx-auto mb-3"
              >
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <polyline points="21 15 16 10 5 21" />
              </svg>
              <span class="text-white/15 text-sm uppercase tracking-wider">
                About Image
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FAQ SECTION ===================== -->
    <section id="faq" class="section-padding">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <span class="section-label">FAQ</span>
          <h2 class="font-serif text-4xl md:text-5xl text-white mt-3">
            Common Questions
          </h2>
        </div>

        <FAQAccordion client:load />
      </div>
    </section>

    <!-- ===================== CTA SECTION ===================== -->
    <section class="bg-brand-gold py-16 md:py-20 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-brand-dark leading-tight mb-8">
          Ready to Make Your Event Unforgettable?
        </h2>
        <a
          href="/booking"
          class="inline-block bg-brand-dark text-white font-semibold px-10 py-4 tracking-wider text-sm uppercase hover:bg-brand-dark/90 transition-all duration-300"
        >
          Book Your Cart Today
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
