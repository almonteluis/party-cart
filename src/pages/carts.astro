---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Our Carts | Create It Sis" description="Browse our collection of premium mobile party carts available for rental.">
  <Navigation />

  <!-- Hero -->
  <section class="pt-32 pb-16 px-6 md:px-12 lg:px-20 bg-brand-dark">
    <div class="max-w-6xl mx-auto text-center">
      <span class="section-label">Our Collection</span>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl mt-4 mb-6">Choose Your Cart</h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        Each of our premium carts is designed to make your event unforgettable. Browse our collection and find the perfect match.
      </p>
    </div>
  </section>

  <!-- Carts Grid -->
  <section class="section-padding bg-brand-dark">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">

      <!-- Candy Cart -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="aspect-[4/3] bg-brand-dark flex items-center justify-center">
          <div class="text-center text-white/30">
            <svg class="w-16 h-16 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0A2.704 2.704 0 003 15.546M3 12c.523 0 1.046-.151 1.5-.454a2.704 2.704 0 013 0 2.704 2.704 0 003 0 2.704 2.704 0 013 0 2.704 2.704 0 003 0A2.704 2.704 0 0121 12M3 8.546c.523 0 1.046-.151 1.5-.454a2.704 2.704 0 013 0 2.704 2.704 0 003 0 2.704 2.704 0 013 0 2.704 2.704 0 003 0" /></svg>
            <span class="text-sm uppercase tracking-widest">Candy Cart Image</span>
          </div>
        </div>
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Candy Cart</h3>
            <span class="text-brand-gold font-semibold text-xl">$275</span>
          </div>
          <p class="text-white/60 mb-6">A stunning white-finish cart perfect for sweet tables and candy buffets at any celebration.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>White finish</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Holds 20+ candy varieties</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Includes glass jars & scoops</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Perfect for sweet tables</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Cart</a>
        </div>
      </div>

      <!-- Champagne Cart -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="aspect-[4/3] bg-brand-dark flex items-center justify-center">
          <div class="text-center text-white/30">
            <svg class="w-16 h-16 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M5 14.5l-1.43 1.43a2.25 2.25 0 001.59.659h13.68a2.25 2.25 0 001.59-.659L21 14.5" /></svg>
            <span class="text-sm uppercase tracking-widest">Champagne Cart Image</span>
          </div>
        </div>
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Champagne Cart</h3>
            <span class="text-brand-gold font-semibold text-xl">$300</span>
          </div>
          <p class="text-white/60 mb-6">An elegant white cart with silver and brass accents for sophisticated champagne service.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>White with silver/brass poles</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Includes 36 champagne glasses</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Chrome-accented details</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Elegant presentation</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Cart</a>
        </div>
      </div>

      <!-- Snack Cart -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="aspect-[4/3] bg-brand-dark flex items-center justify-center">
          <div class="text-center text-white/30">
            <svg class="w-16 h-16 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12" /></svg>
            <span class="text-sm uppercase tracking-widest">Snack Cart Image</span>
          </div>
        </div>
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Snack Cart</h3>
            <span class="text-brand-gold font-semibold text-xl">$275</span>
          </div>
          <p class="text-white/60 mb-6">A sleek black cart with wood top, ideal for serving up crowd-pleasing snacks at casual events.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Black finish with wood top</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Customizable snack options</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Rustic modern design</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Great for casual events</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Cart</a>
        </div>
      </div>

      <!-- Shot Cart -->
      <div class="bg-brand-charcoal rounded-lg overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
        <div class="aspect-[4/3] bg-brand-dark flex items-center justify-center">
          <div class="text-center text-white/30">
            <svg class="w-16 h-16 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
            <span class="text-sm uppercase tracking-widest">Shot Cart Image</span>
          </div>
        </div>
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl">Shot Cart</h3>
            <span class="text-brand-gold font-semibold text-xl">$350</span>
          </div>
          <p class="text-white/60 mb-6">A bold black cart ready to serve up to 84 shots — built for the life of the party.</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Black finish</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Serves up to 84 shots</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Includes shot glasses & trays</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>Party-ready setup</li>
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Cart</a>
        </div>
      </div>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 px-6 md:px-12 lg:px-20 bg-brand-charcoal text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-serif text-3xl mb-4">Don't See What You Need?</h2>
      <p class="text-white/60 mb-8">Contact us for custom requests. We love bringing unique visions to life.</p>
      <a href="/booking" class="btn-primary">Get in Touch</a>
    </div>
  </section>

  <Footer />
</Layout>
