---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const backdropServices = [
  {
    name: 'Arch Frames',
    price: '$15',
    description: 'Durable arch frames, 6 ft high x 7.2 ft wide x 2.75 in thick. The perfect base for any balloon or backdrop installation.',
    features: ['6 ft high, 7.2 ft wide', 'Durable frame material', 'Can be decorated or left bare', 'Stackable for transport'],
  },
  {
    name: 'Arch Covers',
    price: '$20',
    description: 'Solid color covers to transform your arch frame. Choose your color or upgrade to graphic designs and textured fabrics.',
    features: ['Solid color included', 'Custom graphics available', 'Textured fabric upgrade', 'Perfect fit for arch frames'],
  },
  {
    name: 'Curtain + Frame',
    price: '$30',
    description: 'Complete curtain and frame setup measuring 8 ft high by 10 ft wide. Creates an elegant backdrop or room divider.',
    features: ['8 ft high x 10 ft wide', 'Frame included', 'Custom designs available', 'Professional installation'],
  },
  {
    name: '5ft Balloon Installation',
    price: '$160',
    description: 'A stunning 5-foot tall balloon arrangement. Delivery included. Balloons sold separately.',
    features: ['5 ft tall installation', 'Delivery included', 'Professional setup', 'Balloons sold separately'],
  },
  {
    name: '7.2ft Arch Balloons',
    price: '$200',
    description: 'Our signature 7.2-foot tall balloon arch. A show-stopping centerpiece for any event. Delivery included, balloons sold separately.',
    features: ['7.2 ft tall arch', 'Delivery included', 'Professional installation', 'Balloons sold separately'],
  },
  {
    name: 'Balloon Garland',
    price: '$120',
    description: 'A beautiful 6-foot long balloon garland. Perfect for table displays, doorways, and photo backdrops. Delivery included.',
    features: ['6 ft long garland', 'Delivery included', 'Professional arrangement', 'Bottom arrangement available at extra cost'],
  },
  {
    name: 'Balloon Spiral',
    price: '$120',
    description: 'An eye-catching 6-foot long balloon spiral arrangement. Adds a unique visual element to any celebration. Delivery included.',
    features: ['6 ft long spiral', 'Delivery included', 'Professional arrangement', 'Bottom arrangement available at extra cost'],
  },
];
---

<Layout title="Our Services | Create It Sis" description="Browse our backdrop, balloon installations, and event services with pricing.">
  <Navigation />

  <!-- Hero -->
  <section class="pt-32 pb-16 px-6 md:px-12 lg:px-20 bg-brand-dark">
    <div class="max-w-6xl mx-auto text-center">
      <span class="section-label">Our Services</span>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl mt-4 mb-6">Backdrop &amp; Balloon Services</h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        From arch frames to full balloon installations, we create stunning backdrops for every occasion.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section-padding bg-brand-dark">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">

      {backdropServices.map((service) => (
        <div class="bg-brand-charcoal rounded-lg p-8 hover:-translate-y-1 transition-transform duration-300 border border-white/5 hover:border-brand-pink/20">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-serif text-2xl text-white">{service.name}</h3>
            <span class="text-brand-pink font-bold text-2xl">{service.price}</span>
          </div>
          <p class="text-white/60 mb-6">{service.description}</p>
          <ul class="space-y-2 mb-6 text-white/50 text-sm">
            {service.features.map((feature) => (
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-brand-pink rounded-full flex-shrink-0"></span>
                {feature}
              </li>
            ))}
          </ul>
          <a href="/booking" class="btn-primary w-full text-center">Book This Service</a>
        </div>
      ))}

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 px-6 md:px-12 lg:px-20 bg-brand-charcoal text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-serif text-3xl mb-4">Need Something Custom?</h2>
      <p class="text-white/60 mb-8">Contact us for custom backdrop designs and balloon arrangements. We love bringing unique visions to life!</p>
      <a href="/booking" class="btn-primary">Get in Touch</a>
    </div>
  </section>

  <Footer />
</Layout>
