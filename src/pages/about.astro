---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us | Create It Sis" description="Learn about Create It Sis — premier event decor, balloon installations, and party rental service.">
  <Navigation />

  <!-- Hero -->
  <section class="pt-32 pb-16 px-6 md:px-12 lg:px-20 bg-brand-dark">
    <div class="max-w-6xl mx-auto text-center">
      <span class="section-label">About Us</span>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl mt-4 mb-6">About Create It Sis</h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        Let's create together! Quality service, affordable prices, and a professional touch.
      </p>
    </div>
  </section>

  <!-- Our Story -->
  <section class="section-padding bg-brand-dark">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="section-label">Our Story</span>
        <h2 class="font-serif text-3xl md:text-4xl mt-3 mb-6">Bringing Your Vision to Life</h2>
        <p class="text-white/60 mb-4">
          Create It Sis was born from a passion for creating memorable celebrations. Based in Middletown, NY, we specialize in stunning balloon installations, backdrop designs, luxury dessert cart rentals, and full event planning services.
        </p>
        <p class="text-white/60 mb-4">
          From intimate birthday gatherings to grand weddings and corporate events, we bring creativity and professionalism to every occasion. Our team handles delivery, setup, and breakdown so you can focus on what matters most — celebrating with the people you love.
        </p>
        <p class="text-white/60">
          What started as a passion for creating beautiful events has grown into a trusted service across the New York area. We treat every event like it's our own, because to us, it is.
        </p>
      </div>
      <div class="space-y-4">
        <div class="bg-brand-charcoal rounded-lg p-8 flex items-center justify-center">
          <img src="/images/logo.png" alt="Create It Sis Logo" class="w-48 h-48 rounded-full object-contain" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-brand-charcoal rounded-lg overflow-hidden aspect-square">
            <img src="/images/dessert-cart.png" alt="Our Dessert Cart" class="w-full h-full object-contain p-3" />
          </div>
          <div class="bg-brand-charcoal rounded-lg overflow-hidden aspect-square">
            <img src="/images/cylinder-pedestals.png" alt="Event Decor" class="w-full h-full object-contain p-3" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Mission -->
  <section class="section-padding bg-brand-charcoal">
    <div class="max-w-3xl mx-auto text-center">
      <span class="section-label">Our Mission</span>
      <h2 class="font-serif text-3xl md:text-4xl mt-3 mb-6">Delivering Exceptional Experiences</h2>
      <p class="text-white/60 text-lg leading-relaxed">
        Our mission is to transform ordinary events into extraordinary memories. We believe every milestone deserves to be celebrated with style, and we're committed to providing premium, hassle-free event decor and rental services that let you focus on enjoying the moment.
      </p>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section-padding bg-brand-dark">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <span class="section-label">Why Choose Us</span>
        <h2 class="font-serif text-3xl md:text-4xl mt-3">What Sets Us Apart</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-pink/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
          </div>
          <h3 class="font-serif text-xl mb-2">Quality Service</h3>
          <p class="text-white/50 text-sm">Professional service from booking to breakdown. We handle every detail with care.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-pink/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
          </div>
          <h3 class="font-serif text-xl mb-2">Affordable Prices</h3>
          <p class="text-white/50 text-sm">Premium event services starting at just $15. Beautiful events don't have to break the bank.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-pink/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25" /></svg>
          </div>
          <h3 class="font-serif text-xl mb-2">Custom Packages</h3>
          <p class="text-white/50 text-sm">Tailored packages that fit your vision and budget. We bring your ideas to life.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-pink/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25h3.75L8.25 5.25H5.625" /></svg>
          </div>
          <h3 class="font-serif text-xl mb-2">Reliable Delivery</h3>
          <p class="text-white/50 text-sm">On-time delivery, professional setup, and prompt pickup across NY and 20-mile radius.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="section-padding bg-brand-charcoal">
    <div class="max-w-3xl mx-auto text-center">
      <span class="section-label">Service Area</span>
      <h2 class="font-serif text-3xl md:text-4xl mt-3 mb-6">New York, NY &amp; 20-Mile Radius</h2>
      <p class="text-white/60 text-lg leading-relaxed mb-6">
        Based in Middletown, NY, we serve the greater New York area within a 20-mile radius. Additional travel fees may apply for locations outside our standard service area.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <div class="text-center">
          <span class="text-brand-pink font-bold text-3xl block">845-978-2472</span>
          <span class="text-white/40 text-xs uppercase tracking-wider">Call or Text</span>
        </div>
        <div class="hidden sm:block w-px h-12 bg-white/10"></div>
        <div class="text-center">
          <span class="text-brand-pink font-bold text-3xl block">@CREATE_IT_85</span>
          <span class="text-white/40 text-xs uppercase tracking-wider">Instagram</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 md:px-12 lg:px-20 bg-brand-gold text-brand-dark text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl mb-4">Ready to Celebrate?</h2>
      <p class="text-brand-dark/70 mb-8">Let us help make your next event one to remember.</p>
      <a href="/booking" class="inline-block bg-brand-dark text-white font-semibold px-8 py-3.5 tracking-wider text-sm uppercase hover:bg-brand-dark/90 transition-all duration-300">Book Your Event</a>
    </div>
  </section>

  <Footer />
</Layout>
