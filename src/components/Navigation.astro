---
const navLinks = [
  { label: 'Home', href: '/#home' },
  { label: 'Our Carts', href: '/#carts' },
  { label: 'Packages', href: '/#packages' },
  { label: 'How It Works', href: '/#how-it-works' },
  { label: 'About', href: '/#about' },
];
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <nav class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-20">
    <!-- Logo -->
    <a
      href="/#"
      class="font-serif text-2xl md:text-3xl text-white tracking-wide hover:text-brand-gold transition-colors duration-300"
    >
      Create It Sis
    </a>

    <!-- Desktop Nav Links -->
    <ul class="hidden lg:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-white/80 text-sm uppercase tracking-widest font-medium hover:text-brand-gold transition-colors duration-300"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <a
      href="/booking"
      class="hidden lg:inline-block btn-primary text-xs"
    >
      Book Now
    </a>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-toggle"
      class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
    >
      <span class="hamburger-line block w-6 h-0.5 bg-white transition-all duration-300 origin-center"></span>
      <span class="hamburger-line block w-6 h-0.5 bg-white transition-all duration-300 origin-center"></span>
      <span class="hamburger-line block w-6 h-0.5 bg-white transition-all duration-300 origin-center"></span>
    </button>
  </nav>

  <!-- Mobile Menu Panel -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-brand-dark/98 backdrop-blur-lg border-t border-white/10"
  >
    <ul class="flex flex-col items-center gap-6 py-10 px-6">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link text-white/80 text-base uppercase tracking-widest font-medium hover:text-brand-gold transition-colors duration-300"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-2">
        <a href="/booking" class="btn-primary text-xs">Book Now</a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Scroll behavior: add solid background on scroll
  const nav = document.getElementById('site-nav');

  function handleScroll() {
    if (!nav) return;
    if (window.scrollY > 50) {
      nav.classList.add('bg-scrolled');
    } else {
      nav.classList.remove('bg-scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerLines = toggle?.querySelectorAll('.hamburger-line');

  toggle?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');

    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      hamburgerLines?.forEach((line) => {
        line.classList.remove('rotate-45', '-rotate-45', 'opacity-0', 'translate-y-2', '-translate-y-2');
      });
    } else {
      mobileMenu?.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      hamburgerLines?.forEach((line, i) => {
        if (i === 0) line.classList.add('rotate-45', 'translate-y-2');
        if (i === 1) line.classList.add('opacity-0');
        if (i === 2) line.classList.add('-rotate-45', '-translate-y-2');
      });
    }
  });

  // Close mobile menu when a link is clicked
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      hamburgerLines?.forEach((line) => {
        line.classList.remove('rotate-45', '-rotate-45', 'opacity-0', 'translate-y-2', '-translate-y-2');
      });
    });
  });
</script>

<style>
  #site-nav.bg-scrolled {
    background-color: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
</style>
